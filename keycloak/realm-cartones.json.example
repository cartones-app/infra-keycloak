{
  "_comment": "Template GENÉRICO de realm. Copiar a realm-cartones.json (gitignoreado), reemplazar __FRONTEND_HOST__ y __CLIENT_SECRET__, y customizar según entorno. El docker-compose.local.yml monta realm-cartones.json y lo importa al boot (--import-realm es idempotente: si el realm ya existe lo skipea; para reimportar, `docker compose down -v`).",
  "_dev_setup": "Para LOCAL: __FRONTEND_HOST__=localhost:3000, agregar `\"sslRequired\": \"none\"` al objeto raíz, y opcionalmente sumar users seed (ver bloque _local_users_seed más abajo).",
  "_prod_setup": "Para PROD: __FRONTEND_HOST__=tu-dominio.com (sin http://), generar __CLIENT_SECRET__ con `openssl rand -hex 32` (también va al frontend como AUTH_KEYCLOAK_SECRET). Mantener sslRequired=external. NO commitear este archivo resuelto.",
  "_local_users_seed": [
    { "username": "admin",        "password": "admin123",        "email": "admin@cartones.local",        "firstName": "Admin",        "lastName": "Sistema", "realmRoles": ["ADMIN"] },
    { "username": "distribuidor", "password": "distribuidor123", "email": "distribuidor@cartones.local", "firstName": "Distribuidor", "lastName": "Demo",    "realmRoles": ["DISTRIBUIDOR"] }
  ],

  "realm": "cartones",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "loginTheme": "cartones",
  "accountTheme": "cartones",
  "emailTheme": "cartones",
  "bruteForceProtected": true,
  "permanentLockout": false,
  "failureFactor": 5,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "passwordPolicy": "length(12) and upperCase(1) and lowerCase(1) and digits(1) and notUsername",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "roles": {
    "realm": [
      { "name": "ADMIN",        "description": "Acceso total: operaciones de negocio, panel de administración y métricas" },
      { "name": "DISTRIBUIDOR", "description": "Acceso a operaciones de negocio del día a día" }
    ]
  },
  "clients": [
    {
      "clientId": "frontend",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "https://__FRONTEND_HOST__/*"
      ],
      "webOrigins": [
        "https://__FRONTEND_HOST__"
      ],
      "defaultClientScopes": ["basic", "profile", "email", "roles", "web-origins"],
      "optionalClientScopes": ["address", "phone", "offline_access"]
    }
  ],
  "users": []
}
