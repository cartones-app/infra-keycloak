{
  "realm": "cartones",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "loginTheme": "cartones",
  "accountTheme": "cartones",
  "emailTheme": "cartones",
  "roles": {
    "realm": [
      { "name": "ADMIN",       "description": "Acceso total: operaciones de negocio, panel de administración y métricas" },
      { "name": "DISTRIBUIDOR","description": "Acceso a operaciones de negocio del día a día" }
    ]
  },
  "clients": [
    {
      "clientId": "frontend",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "_comment_secret": "DEV-ONLY well-known secret. Está en git a propósito: este realm.local.json se importa idéntico en todas las máquinas de dev. No es un secret real — cualquiera con acceso al repo lo conoce. Para prod usar realm-cartones.prod.json.example, que tiene placeholder __CLIENT_SECRET__ resuelto por sed antes del import (ese sí queda gitignoreado).",
      "secret": "dev-only-frontend-secret-no-usar-en-prod",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "http://localhost:3000/*",
        "https://rgq-web.vercel.app/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "https://rgq-web.vercel.app"
      ],
      "defaultClientScopes": ["basic", "profile", "email", "roles", "web-origins"],
      "optionalClientScopes": ["address", "phone", "offline_access"]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@cartones.local",
      "firstName": "Admin",
      "lastName": "Sistema",
      "credentials": [
        { "type": "password", "value": "admin123", "temporary": true }
      ],
      "realmRoles": ["ADMIN"]
    },
    {
      "username": "distribuidor",
      "enabled": true,
      "email": "distribuidor@cartones.local",
      "firstName": "Distribuidor",
      "lastName": "Demo",
      "credentials": [
        { "type": "password", "value": "distribuidor123", "temporary": true }
      ],
      "realmRoles": ["DISTRIBUIDOR"]
    }
  ]
}
