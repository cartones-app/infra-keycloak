# Copiar como .env y completar. .env está en .gitignore.

# ----------------------------------------------------------------------------
# Admin de Keycloak (consola web /admin)
# ----------------------------------------------------------------------------
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=cambiar_en_prod

# ----------------------------------------------------------------------------
# Base de datos (Postgres dedicada del Keycloak)
# ----------------------------------------------------------------------------
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=cambiar_en_prod

# ----------------------------------------------------------------------------
# Hostname público — debe matchear el dominio donde se sirve Keycloak.
# En local sobrescribe el override de compose.local con KC_HOSTNAME=localhost.
# ----------------------------------------------------------------------------
KC_HOSTNAME=keycloak.midominio.com

# Puerto HTTP interno expuesto (atrás de proxy en prod, abierto en local).
KEYCLOAK_HTTP_PORT=8080
